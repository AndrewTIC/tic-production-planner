# Copy to .env.local (gitignored) and fill in from `supabase start` output.
# The same variable names work unchanged against the office-server stack later —
# environment parity is the governing principle (spec §8a).

# Local Supabase API URL (printed by `supabase start`; this project uses
# 443xx ports — see the note at the top of supabase/config.toml)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:44321

# Local anon key (printed by `supabase start` — safe to expose to the browser;
# RLS is what protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-anon-key-from-supabase-start

# Service-role key (printed by `supabase start`). Server-side only — never
# expose with a NEXT_PUBLIC_ prefix. Not used by the app yet; documented for
# admin scripts (e.g. creating users).
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key-from-supabase-start
